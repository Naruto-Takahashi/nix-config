{
  "$schema": "https://github.com/glzr-io/zebar/raw/v3.2.0/resources/zpack-schema.json",
  "name": "custom",
  "version": "1.0.0",
  "description": "Transparent island-style status bar for GlazeWM",
  "tags": ["glazewm", "transparent", "minimal"],
  "previewImages": [],
  "repositoryUrl": "",
  "widgets": [
    {
      "name": "status-bar",
      "htmlPath": "status-bar/index.html",
      "zOrder": "bottom_most",
      "shownInTaskbar": false,
      "focused": false,
      "resizable": false,
      "transparent": true,
      "includeFiles": [
        "status-bar/**"
      ],
      "caching": {
        "defaultDuration": 604800,
        "rules": []
      },
      "privileges": {
        "shellCommands": []
      },
      "presets": [
        {
          "name": "default",
          "anchor": "top_left",
          "offsetX": "8px",
          "offsetY": "4px",
          "width": "calc(100% - 16px)",
          "height": "26px",
          "monitorSelection": {
            "type": "all"
          },
          "dockToEdge": {
            "enabled": true,
            "edge": "top",
            "windowMargin": "0px"
          }
        }
      ]
    }
  ]
}