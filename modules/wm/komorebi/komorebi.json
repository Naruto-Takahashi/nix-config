{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.38/schema.json",
  "app_specific_configuration_path": "$Env:USERPROFILE/applications.json",
  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",
  "transparency": false,
  "transparency_alpha": 252,
  "default_workspace_padding": 1,
  "resize_delta": 100,
  "default_container_padding": 6,
  "border": true,
  "border_width": 6,
  "border_offset": 0,
  "mouse_follows_focus": true,
  "animation": {
    "enabled": false,
    "duration": 200,
    "fps": 60,
    "style": {
      "movement": "EaseInOutQuad",
      "transparency": "Linear"
    }
  },
  "border_colours": {
    "single": "#86d1e9",
    "unfocused": "#899296",
    "floating": "#86d1e9",
    "monocle": "#c1c4eb"
  },
  "display_index_preferences": {
    "0": "150995873",
    "1": "6306110015143"
  },
  "monitors": [
    {
      "workspaces": [
        {
          "name": "1",
          "layout": "BSP"
        },
        {
          "name": "2",
          "layout": "Grid"
        },
        {
          "name": "3",
          "layout": "HorizontalStack"
        },
        {
          "name": "4",
          "layout": "BSP"
        },
        {
          "name": "5",
          "layout": "BSP"
        }
      ]
    },
    {
      "workspaces": [
        {
          "name": "6",
          "layout": "BSP"
        },
        {
          "name": "7",
          "layout": "Grid"
        },
        {
          "name": "8",
          "layout": "HorizontalStack"
        },
        {
          "name": "9",
          "layout": "BSP"
        }
      ]
    }
  ],
  "ignore_rules": [
    {
      "kind": "Exe",
      "id": "ACShadows.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "Overwatch.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "PotPlayerMini64.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "Files.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "Microsoft.CmdPal.UI.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "SnippingTool.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "ScreenClippingHost.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Title",
      "id": "切り取り領域とスケッチ",
      "matching_strategy": "Contains"
    },
    {
      "kind": "Title",
      "id": "Snipping Tool",
      "matching_strategy": "Contains"
    }
  ]
}
