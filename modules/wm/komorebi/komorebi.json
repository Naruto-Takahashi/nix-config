{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/main/schema.json",
  "app_specific_configuration_path": "~/.config/komorebi/applications.json",
  "window_hiding_behaviour": "Minimize",
  "cross_monitor_move_behaviour": "Swap",
  "default_workspace_padding": 4,
  "default_container_padding": 4,
  "border": true,
  "border_width": 4,
  "border_offset": -1,
  "border_implementation": "Komorebi",
  "border_colours": {
    "single": "#ffc20d",
    "stack": "#ffc20d",
    "monocle": "#ffc20d",
    "unfocused": "#333333",
    "floating": "#ffd147"
  },
  "monitors": [
    {
      "workspaces": [
        { "name": "1", "layout": "Bsp" },
        { "name": "2", "layout": "Bsp" },
        { "name": "3", "layout": "Bsp" },
        { "name": "4", "layout": "Bsp" },
        { "name": "5", "layout": "Bsp" },
        { "name": "6", "layout": "Bsp" },
        { "name": "7", "layout": "Bsp" },
        { "name": "8", "layout": "Bsp" },
        { "name": "9", "layout": "Bsp" }
      ]
    }
  ]
}
