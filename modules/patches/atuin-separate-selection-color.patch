atuin v18 の履歴リストを fzf の見た目に寄せるパッチ:
 1. 選択行のコマンド文字色を AlertError (失敗色と共有) から Base に変更
 2. vim-normal 限定の REVERSED 反転を廃止
 3. 選択行は行全体に fzf の bg+ と同じ背景 (Indexed 236 = #303030) を敷く
 4. command 列の描画後にカーソルを列幅まで進め、後続の列 (time 等) が
    右端に揃うようにする (ui.columns = ["duration","command","time"] 用)
 5. 右端の枠との間に 1 文字分の余白を確保する
--- a/crates/atuin/src/command/client/search/history_list.rs	2026-07-19 13:31:28.338952332 +0900
+++ b/crates/atuin/src/command/client/search/history_list.rs	2026-07-19 13:31:28.376932954 +0900
@@ -107,6 +107,18 @@
         };
 
         for item in self.history.iter().skip(state.offset).take(end - start) {
+            // fzf-style full-width background for the selected row
+            if s.y as usize + s.state.offset == s.state.selected {
+                let cy = if s.inverted {
+                    s.list_area.top() + s.y
+                } else {
+                    s.list_area.bottom() - s.y - 1
+                };
+                s.buf.set_style(
+                    Rect::new(s.list_area.left(), cy, s.list_area.width, 1),
+                    ratatui::style::Style::default().bg(ratatui::style::Color::Indexed(236)),
+                );
+            }
             s.render_row(item);
 
             // reset line
@@ -198,10 +210,11 @@
             .filter(|c| !c.expand)
             .map(|c| c.width + 1)
             .sum();
+        // 右端の枠との間に 1 文字分の余白を確保する
         let expand_width = self
             .list_area
             .width
-            .saturating_sub(indicator_width + fixed_width);
+            .saturating_sub(indicator_width + fixed_width + 1);
 
         let style = self.theme.as_style(Meaning::Base);
         // Render each configured column
@@ -222,7 +235,11 @@
                 UiColumnType::Host => self.host(h, width),
                 UiColumnType::User => self.user(h, width),
