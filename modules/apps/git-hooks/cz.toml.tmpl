[tool.commitizen]
name = "cz_customize"
# questionary(対話UI)の配色。ANSIパレットとは独立にRGB直書きで効く。
# matugen環境ではこのファイルの代わりに~/.cache/matugen/cz.toml
# (テーマ由来の色) が使われる (modules/theming/matugen/templates/cz.toml)。
# ここはmatugenが無い環境向けのフォールバック値 (kanagawa-dragon系)。
style = [
  ["qmark", "fg:#e6c384 bold"],
  ["question", "bold"],
  ["answer", "fg:#e6c384 bold"],
  ["pointer", "fg:#e6c384 bold"],
  ["highlighted", "fg:#e6c384 bold"],
  ["selected", "fg:#7aa89f"],
  ["separator", "fg:#a292a3"],
  ["instruction", ""],
  ["text", ""],
  ["disabled", "fg:#a6a69c italic"],
]

[tool.commitizen.customize]
# scope が deps/deps-dev のときは prepare-commit-msg フックと同じ規約で
# ⬆️/⬇️ に上書きする (Renovate/Dependabot慣例、cz commit経由でも
# 手書きコミットと同じ挙動にするため)。
message_template = "{% if scope in ['deps', 'deps-dev'] %}{% if 'downgrade' in subject.lower() %}⬇️{% else %}⬆️{% endif %} {{change_type.split(' ', 1)[1]}}{% else %}{{change_type}}{% endif %}{% if scope %}({{scope}}){% endif %}: {{subject}}"
example = "✨ feat(nvim): add gitmoji plugin"
schema = "<gitmoji> <type>(<scope>): <subject>"
schema_pattern = ".+"

[[tool.commitizen.customize.questions]]
type = "list"
name = "change_type"
message = "Select the type of change:"
# 選択肢は gitmoji-types.txt (単一ソース) から生成される。
# prepare-commit-msgのMAPと同じファイルを見ているので、
# 追加/変更はgitmoji-types.txtを直すだけで両方に反映される。
choices = [
@@GITMOJI_CZ_CHOICES@@
]

# scopeはリポジトリごとに意味が変わるため自由入力にする
# (どのリポジトリでも同じ設定を使い回せるように、固定リストにしない)
[[tool.commitizen.customize.questions]]
type = "input"
name = "scope"
message = "Scope (optional, e.g. nvim / deps):"

[[tool.commitizen.customize.questions]]
type = "input"
name = "subject"
message = "Subject:"
