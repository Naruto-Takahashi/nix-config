#!/usr/bin/env bash
# =========================================================================
# gitmoji 強制バリデーション (commit-msg)
# =========================================================================
# prepare-commit-msgが常にデフォルト絵文字(💬)を付けるため通常は素通りするが、
# 手動編集などで絵文字が消えた場合に警告だけ出す(コミット自体は拒否しない)。
# git CLI直接実行、lazygit(nvim内/外)、Claude CodeなどのAIエージェント
# 経由のコミットも、最終的にgit commitを呼ぶ限りこのフックを通る。
#
# 絵文字はコードポイント数が可変(結合絵文字や異体字セレクタ付きなど)なため、
# bashの正規表現ブラケット表現には入れず、配列との前方一致で判定する。
set -euo pipefail

MSG_FILE="$1"
FIRST_LINE="$(head -n1 "$MSG_FILE")"

# merge commit / fixup! / squash! はチェック対象外
if [[ "$FIRST_LINE" =~ ^Merge ]] || [[ "$FIRST_LINE" =~ ^(fixup|squash)! ]]; then
  exit 0
fi

# :shortcode: 形式ならOK
if [[ "$FIRST_LINE" =~ ^[[:space:]]*:[a-z_]+: ]]; then
  exit 0
fi

GITMOJIS=(
  🎨 🐛 ✨ 📝 ♻️ ⚡️ ✅ 🔧 📦️ 👷 ⏪️ 🚧 🔥 🔒️ ➕ ➖ ⬆️ ⬇️ 🎉 💚 🔀 💄
  🍎 🐧 🪟 📱 🚀 🔖 🚨 🚑️ 👥 🔊 🔇 🙈 📸 ⚗️ 🔍️ ♿️ 💡 🍻 💬 🗃️ 🚸 🏗️
  🤡 🥚 🌐 💫 🗑️ 🛂 🩹 🧐 ⚰️ 🧪 👔 🩺 🧱 🧑‍💻
)

for emoji in "${GITMOJIS[@]}"; do
  if [[ "$FIRST_LINE" == "$emoji"* ]]; then
    exit 0
  fi
done

echo "⚠ commit message has no gitmoji (e.g. ✨ feat: ...) — proceeding anyway" >&2
echo "  see: https://gitmoji.dev" >&2
echo "  got: ${FIRST_LINE}" >&2
exit 0
