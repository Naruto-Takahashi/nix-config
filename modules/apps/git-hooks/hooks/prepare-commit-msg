#!/usr/bin/env bash
# =========================================================================
# gitmoji 自動付与フック (prepare-commit-msg)
# =========================================================================
# Conventional Commits 風の接頭辞 (feat:, fix: など) からgitmojiを推定し、
# メッセージ先頭に自動で付与する。推定できない場合もデフォルト絵文字を
# 付けるため、commit-msg側のチェックに引っかかることはほぼ無い。
# 既にgitmojiが付いている場合や merge/squash はスキップする。
set -euo pipefail

MSG_FILE="$1"
SOURCE="${2:-}"

# merge/squash コミット、テンプレートからの生成はスキップ
case "$SOURCE" in
  merge|squash) exit 0 ;;
esac

FIRST_LINE="$(head -n1 "$MSG_FILE")"

# type→絵文字の対応表は gitmoji-types.txt (単一ソース) から読み込む。
# 同じファイルを .cz.toml (cz commit の選択肢) の生成にも使っており、
# 追加/変更はそちらの1ファイルを直すだけで両方に反映される。
declare -A MAP=()
TYPES_FILE="$(dirname "$0")/../gitmoji-types.txt"
if [[ -f "$TYPES_FILE" ]]; then
  while read -r gm_type gm_emoji; do
    [[ -z "$gm_type" ]] && continue
    MAP[$gm_type]="$gm_emoji"
  done < "$TYPES_FILE"
fi
DEFAULT_EMOJI="💬"

GITMOJIS=(
  🎨 🐛 ✨ 📝 ♻️ ⚡️ ✅ 🔧 📦️ 👷 ⏪️ 🚧 🔥 🔒️ ➕ ➖ ⬆️ ⬇️ 🎉 💚 🔀 💄
  🍎 🐧 🪟 📱 🚀 🔖 🚨 🚑️ 👥 🔊 🔇 🙈 📸 ⚗️ 🔍️ ♿️ 💡 🍻 💬 🗃️ 🚸 🏗️
  🤡 🥚 🌐 💫 🗑️ 🛂 🩹 🧐 ⚰️ 🧪 👔 🩺 🧱 🧑‍💻
)

# 既にgitmoji (絵文字 or :shortcode:) が付いていれば何もしない
if [[ "$FIRST_LINE" =~ ^[[:space:]]*:[a-z_]+: ]]; then
  exit 0
fi
for emoji in "${GITMOJIS[@]}"; do
  if [[ "$FIRST_LINE" == "$emoji"* ]]; then
    exit 0
  fi
done

# "feat(scope): subject" / "feat: subject" の接頭辞とscopeを抽出
TYPE=""
SCOPE=""
if [[ "$FIRST_LINE" =~ ^([a-zA-Z]+)\(([^\)]*)\)?!?:[[:space:]] ]]; then
  TYPE="${BASH_REMATCH[1],,}"
  SCOPE="${BASH_REMATCH[2],,}"
elif [[ "$FIRST_LINE" =~ ^([a-zA-Z]+)!?:[[:space:]] ]]; then
  TYPE="${BASH_REMATCH[1],,}"
fi

EMOJI="$DEFAULT_EMOJI"
if [[ -n "$TYPE" && -n "${MAP[$TYPE]+set}" ]]; then
  EMOJI="${MAP[$TYPE]}"
fi

# scope(deps) / scope(deps-dev) は依存関係更新として扱う
# (Renovate/Dependabot慣例の "chore(deps): bump X" 等に合わせる)
if [[ "$SCOPE" == "deps" || "$SCOPE" == "deps-dev" ]]; then
  if [[ "$FIRST_LINE" =~ [Dd]owngrade ]]; then
    EMOJI="⬇️"
  else
    EMOJI="⬆️"
  fi
fi

sed -i "1s/^/${EMOJI} /" "$MSG_FILE"

exit 0
