#!/usr/bin/env bash
# =========================================================================
# gitmoji 自動付与フック (prepare-commit-msg)
# =========================================================================
# Conventional Commits 風の接頭辞 (feat:, fix: など) からgitmojiを推定し、
# メッセージ先頭に自動で付与する。すでにgitmojiが付いている場合や
# merge/squash/amendの一部ケースはスキップする。
set -euo pipefail

MSG_FILE="$1"
SOURCE="${2:-}"

# merge/squash コミット、テンプレートからの生成はスキップ
case "$SOURCE" in
  merge|squash) exit 0 ;;
esac

FIRST_LINE="$(head -n1 "$MSG_FILE")"

# 既にgitmoji (絵文字 or :shortcode:) が付いていれば何もしない
if [[ "$FIRST_LINE" =~ ^[[:space:]]*: || "$FIRST_LINE" =~ ^[🎨🐛✨📝♻️⚡️✅🔧📦️👷⏪️🚧🔥🔒️➕➖⬆️⬇️🎉💚🔀💄] ]]; then
  exit 0
fi

declare -A MAP=(
  [feat]="✨"
  [fix]="🐛"
  [docs]="📝"
  [style]="🎨"
  [refactor]="♻️"
  [perf]="⚡️"
  [test]="✅"
  [chore]="🔧"
  [build]="📦️"
  [ci]="👷"
  [revert]="⏪️"
  [wip]="🚧"
  [remove]="🔥"
  [security]="🔒️"
  [init]="🎉"
  [debug]="💚"
  [merge]="🔀"
)

# "feat(scope): subject" / "feat: subject" の接頭辞を抽出
TYPE=""
if [[ "$FIRST_LINE" =~ ^([a-zA-Z]+)(\([^\)]*\))?!?:[[:space:]] ]]; then
  TYPE="${BASH_REMATCH[1]}"
  TYPE="${TYPE,,}"
fi

EMOJI=""
if [[ -n "$TYPE" && -n "${MAP[$TYPE]+set}" ]]; then
  EMOJI="${MAP[$TYPE]}"
fi
if [[ -n "$EMOJI" ]]; then
  sed -i "1s/^/${EMOJI} /" "$MSG_FILE"
fi

exit 0
